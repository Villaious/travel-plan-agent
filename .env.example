# 高德地图 Web服务 API Key
# 申请入口：https://console.amap.com/
AMAP_API_KEY=
AMAP_TIMEOUT=10

# OpenAI 兼容 LLM API
# OpenAI 默认：https://api.openai.com/v1
# 也可替换为 DeepSeek / 阿里云百炼 / ModelScope 等兼容 /chat/completions 的地址
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_TIMEOUT=60

# 是否让规划 Agent 调用 LLM 增强总结和建议
# 未配置 LLM_API_KEY 时会自动回退规则生成
TRAVEL_AGENT_USE_LLM=true
